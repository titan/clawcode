/* ClawCode Catppuccin Mocha Theme */

/* Global settings */
Screen {
    background: #1e1e2e;
}

/* Header */
Header {
    background: #313244;
    text-align: center;
    text-style: bold;
    dock: top;
    height: 1;
    padding: 0 1;
}

Header.-tint {
    text-style: bold;
    background: #313244;
}

/* Footer */
Footer {
    background: #313244;
    text-align: center;
    dock: bottom;
    padding: 0 1;
}

/* Main container */
#main_container {
    height: 100%;
    width: 100%;
}

/* Chat container */
#chat_container {
    height: 1fr;
    width: 1fr;
}

/* Sidebar */
#sidebar {
    width: 25;
    min-width: 20;
    max-width: 40;
    dock: left;
    background: #313244;
    border-right: thick #45475a;
}

/* Chat area */
#chat_area {
    width: 1fr;
    height: 1fr;
}

/* Message list */
#message_list {
    height: 1fr;
    width: 1fr;
    padding: 1;
    background: #1e1e2e;
}

/* Welcome message */
#welcome_message {
    width: 100%;
    height: auto;
    margin: 0;
    padding: 0 0;
}

/* Input area */
#message_input {
    dock: bottom;
    height: auto;
    margin: 1;
    background: #1e1e2e;
    border: solid #45475a;
    padding: 1;
}

/* Input help */
.input_help {
    dock: bottom;
    height: 1;
    color: #6c7086;
    padding: 0 1;
    text-align: right;
}

/* Individual message */
.message {
    margin: 1 0;
    padding: 1;
    background: #313244;
    border: solid #45475a;
    border-title-align: left;
    border-title-color: #6c7086;
    border-subtitle-color: #6c7086;
}

.message.user {
    border-title-color: #cba6f7;
    border-title-style: bold;
}

.message.assistant {
    border-title-color: #89b4fa;
    border-title-style: bold;
}

.message.system {
    border-title-color: #a6e3a1;
    border-title-style: bold;
}

.message.tool {
    background: transparent;
    border: none;
    padding: 0 2;
}

/* Message content */
.message_content {
    margin-top: 1;
    text-style: none;
}

/* Thinking content */
.thinking_content {
    color: #6c7086;
    text-style: italic;
    margin-top: 1;
    padding: 0 2;
}

/* Tool call display */
.tool_call {
    background: #313244;
    border: solid #45475a;
    padding: 0 1;
    margin: 0 2;
}

.tool_call_name {
    color: #89b4fa;
    text-style: bold;
}

.tool_call_input {
    color: #6c7086;
    margin-left: 2;
}

/* Tool result display */
.tool_result {
    background: #313244;
    border: solid #45475a;
    padding: 0 1;
    margin: 0 2;
}

.tool_result_content {
    margin-top: 1;
    padding: 0 2;
}

/* Input area */
#input_area {
    dock: bottom;
    height: auto;
    padding: 0 1;
    background: #313244;
    border-top: thick #45475a;
}

/* Input field */
#message_input {
    margin: 1 0;
}

/* Input help text */
.input_help {
    height: 1;
    align: right middle;
    color: #6c7086;
    padding: 0 1;
}

/* Buttons */
Button {
    background: #cba6f7;
    color: #1e1e2e;
    text-style: bold;
    border: none;
    padding: 0 2;
    margin: 0 1;
}

Button:hover {
    background: #89b4fa;
}

Button.-primary {
    background: #cba6f7;
}

Button.-error {
    background: #f38ba8;
}

Button.-success {
    background: #a6e3a1;
}

/* Permission dialog */
#permission_dialog {
    width: 80%;
    height: auto;
    max-height: 20;
    background: #313244;
    border: thick #45475a;
    padding: 1;
}

.permission_header {
    text-style: bold;
    text-align: center;
    color: #f9e2af;
    margin-bottom: 1;
}

.permission_description {
    margin: 1 0;
}

.permission_path {
    color: #89b4fa;
    text-style: bold;
    margin: 1 0;
}

.permission_buttons {
    height: 3;
    align: center middle;
    margin-top: 1;
}

/* Help screen */
#help_screen {
    padding: 2;
}

.help_section {
    margin: 1 0;
}

.help_title {
    color: #cba6f7;
    text-style: bold;
    margin-bottom: 1;
}

.help_key {
    color: #89b4fa;
    text-style: bold;
}

.help_description {
    margin-left: 2;
    color: #cdd6f4;
}

/* Logs screen */
#logs_content {
    height: 1fr;
    overflow-y: auto;
    padding: 1;
}

.log_entry {
    margin: 0 0;
    padding: 0 1;
}

.log_entry.debug {
    color: #6c7086;
}

.log_entry.info {
    color: #cdd6f4;
}

.log_entry.warning {
    color: #f9e2af;
}

.log_entry.error {
    color: #f38ba8;
}

/* Session list */
#session_list {
    height: 1fr;
    overflow-y: auto;
}

.session_item {
    padding: 1;
    margin: 0 1;
}

.session_item:hover {
    background: #cba6f7;
    color: #1e1e2e;
}

.session_item.selected {
    background: #89b4fa;
    color: #1e1e2e;
    text-style: bold;
}

/* Loading indicator */
.loading {
    color: #89b4fa;
    text-style: bold;
}

/* Code blocks */
.code_block {
    background: #1e1e2e;
    border: solid #45475a;
    padding: 1;
    margin: 1 0;
    text-style: none;
}

.code_language {
    color: #6c7086;
    text-style: italic;
    margin-bottom: 1;
}

/* Scrollbar */
ScrollView > VerticalScrollbar {
    background: #313244;
    color: #6c7086;
}

ScrollView > VerticalScrollbar:hover {
    background: #45475a;
    color: #cdd6f4;
}

ScrollView > VerticalScrollbar > .thumb {
    background: #6c7086;
}

ScrollView > VerticalScrollbar:hover > .thumb {
    background: #cdd6f4;
}

/* Session dialog */
#session_dialog {
    width: 80%;
    height: 80%;
    background: #313244;
    border: thick #45475a;
    padding: 1;
}

.dialog_header {
    text-style: bold;
    text-align: center;
    color: #cba6f7;
    margin-bottom: 1;
}

.dialog_input {
    margin: 1 0;
}

/* Model dialog */
#model_dialog {
    width: 80%;
    height: 80%;
    background: #313244;
    border: thick #45475a;
    padding: 1;
}

.dialog_info {
    color: #6c7086;
    margin: 1 0;
}

/* Commands dialog */
#commands_dialog {
    width: 80%;
    height: 80%;
    background: #313244;
    border: thick #45475a;
    padding: 1;
}

.command_item {
    padding: 0 1;
}

/* Dialog buttons */
#session_buttons,
#model_buttons,
#commands_buttons {
    height: 3;
    align: center middle;
    margin-top: 1;
}
